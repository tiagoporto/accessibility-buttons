{
  "name": "accessibility-buttons",
  "version": "4.0.0",
  "description": "Buttons to add/remove contrast and increase/decrease font size.",
  "homepage": "http://tiagoporto.github.io/accessibility-buttons",
  "keywords": [
    "accessibility",
    "button",
    "contrast",
    "font size",
    "increase font",
    "decrease font"
  ],
  "author": {
    "name": "Tiago Porto",
    "url": "http://tiagoporto.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tiagoporto/accessibility-buttons.git"
  },
  "main": "./dist/accessibility-buttons.es.js",
  "typings": "./dist/accessibility-buttons.d.ts",
  "files": [
    "/dist"
  ],
  "license": "MIT",
  "scripts": {
    "start": "webpack-dev-server --hot --config webpack.config.dev.js",
    "lint": "eslint --ext .ts,.js,.vue ./ --max-warnings 0",
    "lint:fix": "npm run lint -- --fix",
    "checks": "npm run check-formatting && npm run check-typing && npm run lint",
    "check-typing": "tsc --noEmit",
    "check-formatting": "prettier --check './**/*.{js,jsx,ts,tsx,html}'",
    "formatting:fix": "prettier --write './**/*.{js,jsx,ts,tsx,html}'",
    "test": "jest",
    "test:bundle": "jest --config ./jest/es.config.js && jest --config ./jest/umd.config.js && jest --config ./jest/umd.min.config.js",
    "test:watch": "npm test -- --watch",
    "test:mutation": "stryker run",
    "test:mutation-report": "stryker run --reporters dashboard",
    "test:coverage": "npm test -- --coverage",
    "coveralls": "cat ./coverage/lcov.info | coveralls",
    "types": "tsc ./src/lib/accessibility-buttons.ts --declarationDir dist --emitDeclarationOnly --declaration",
    "build:site": "rm -rf website && webpack --config webpack.config.prod.js",
    "build": "rollup --config",
    "deploy": "npm run build:site && npx gh-pages -d website",
    "prepublishOnly": "rm -rf dist && npm run build && npm run types",
    "postpublish": "npm run tag && git push --tags",
    "tag": "git tag v$npm_package_version"
  },
  "devDependencies": {
    "@babel/core": "^7.11.4",
    "@babel/plugin-proposal-class-properties": "^7.10.4",
    "@babel/preset-env": "^7.11.0",
    "@babel/preset-typescript": "^7.10.4",
    "@types/jest": "^26.0.10",
    "@typescript-eslint/eslint-plugin": "^3.9.1",
    "@typescript-eslint/parser": "^3.9.1",
    "@vue/compiler-sfc": "^3.2.29",
    "babel-loader": "^8.1.0",
    "css-loader": "^4.2.1",
    "eslint": "^7.7.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-config-standard": "^14.1.1",
    "eslint-config-typescript": "^3.0.0",
    "eslint-plugin-import": "^2.22.0",
    "eslint-plugin-jest": "^23.20.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-standard": "^4.0.1",
    "eslint-plugin-vue": "^7.0.0-beta.2",
    "html-webpack-plugin": "^4.3.0",
    "husky": "^4.2.5",
    "jeet": "^7.2.0",
    "lit-element": "^2.4.0",
    "normalize.css": "^8.0.1",
    "postcss-combine-media-query": "^1.0.1",
    "postcss-loader": "^3.0.0",
    "postcss-preset-env": "^6.7.0",
    "prettier": "^2.0.5",
    "style-loader": "^1.2.1",
    "stylus": "^0.54.8",
    "stylus-loader": "^3.0.2",
    "typescript": "^4.0.2",
    "vue": "^3.4.21",
    "vue-eslint-parser": "^7.1.0",
    "vue-loader": "^17.4.2",
    "vue-template-compiler": "^2.7.16",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.3"
  },
  "dependencies": {
    "core-js": "^3.6.5",
    "svg-to-inline": "^1.0.0-alpha.1"
  }
}
